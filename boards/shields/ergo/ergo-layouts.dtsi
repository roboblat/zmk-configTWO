/*
 * Physical layout for ZMK Studio - generated from the keyboard-layout-editor
 * (KLE) geometry of THIS board (53 physical keys: 25 left + 28 right), so the
 * Studio picture matches the real staggered columns and thumb clusters.
 *
 * Coordinates are in 1/100 of a key unit, taken directly from the KLE raw data.
 * The list has 61 entries to match the 61-position matrix transform 1:1:
 * 53 real keys at their true positions, then 8 "phantom" slots (the unpopulated
 * matrix cells on the right hand) parked together at the bottom-left so they're
 * obviously not real keys.
 *
 * NOTE: positions affect ONLY how the board is drawn in Studio - never the
 * keymap or scanning. If a key shows in the wrong cell, it's purely cosmetic;
 * nudge the x/y on that line. The matrix transform (&default_transform) is
 * attached to this layout in ergo.dtsi.
 */

#include <physical_layouts.dtsi>

/ {
    ergo_physical_layout: ergo_physical_layout {
        compatible = "zmk,physical-layout";
        display-name = "Ergo";

        keys =
              <&key_physical_attrs 100 100  300    0 0 0 0>  /* L0 */
            , <&key_physical_attrs 100 100    0   75 0 0 0>  /* L1 */
            , <&key_physical_attrs 100 100  100   75 0 0 0>  /* L2 */
            , <&key_physical_attrs 100 100  200   75 0 0 0>  /* L3 */
            , <&key_physical_attrs 100 100  400   75 0 0 0>  /* L4 */
            , <&key_physical_attrs 100 100  500   75 0 0 0>  /* L5 */
            , <&key_physical_attrs 100 100  300  100 0 0 0>  /* L6 */
            , <&key_physical_attrs 100 100    0  175 0 0 0>  /* L7 */
            , <&key_physical_attrs 100 100  100  175 0 0 0>  /* L8 */
            , <&key_physical_attrs 100 100  200  175 0 0 0>  /* L9 */
            , <&key_physical_attrs 100 100  400  175 0 0 0>  /* L10 */
            , <&key_physical_attrs 100 100  500  175 0 0 0>  /* L11 */
            , <&key_physical_attrs 100 100  300  200 0 0 0>  /* L12 */
            , <&key_physical_attrs 100 100    0  275 0 0 0>  /* L13 */
            , <&key_physical_attrs 100 100  100  275 0 0 0>  /* L14 */
            , <&key_physical_attrs 100 100  200  275 0 0 0>  /* L15 */
            , <&key_physical_attrs 100 100  400  275 0 0 0>  /* L16 */
            , <&key_physical_attrs 100 100  500  275 0 0 0>  /* L17 */
            , <&key_physical_attrs 100 100  300  300 0 0 0>  /* L18 */
            , <&key_physical_attrs 100 100    0  375 0 0 0>  /* L19 */
            , <&key_physical_attrs 100 100  100  375 0 0 0>  /* L20 */
            , <&key_physical_attrs 100 100  200  375 0 0 0>  /* L21 */
            , <&key_physical_attrs 100 100  400  375 0 0 0>  /* L22 */
            , <&key_physical_attrs 100 100  500  375 0 0 0>  /* L23 */
            , <&key_physical_attrs 100 100  300  400 0 0 0>  /* L24 */
            , <&key_physical_attrs 100 100 1300    0 0 0 0>  /* R0 */
            , <&key_physical_attrs 100 100 1100   75 0 0 0>  /* R1 */
            , <&key_physical_attrs 100 100 1200   75 0 0 0>  /* R2 */
            , <&key_physical_attrs 100 100 1400   75 0 0 0>  /* R3 */
            , <&key_physical_attrs 100 100 1500   75 0 0 0>  /* R4 */
            , <&key_physical_attrs 100 100 1600   75 0 0 0>  /* R5 */
            , <&key_physical_attrs 100 100 1300  100 0 0 0>  /* R6 */
            , <&key_physical_attrs 100 100 1100  175 0 0 0>  /* R7 */
            , <&key_physical_attrs 100 100 1200  175 0 0 0>  /* R8 */
            , <&key_physical_attrs 100 100 1400  175 0 0 0>  /* R9 */
            , <&key_physical_attrs 100 100 1500  175 0 0 0>  /* R10 */
            , <&key_physical_attrs 100 100 1600  175 0 0 0>  /* R11 */
            , <&key_physical_attrs 100 100 1300  200 0 0 0>  /* R12 */
            , <&key_physical_attrs 100 100 1100  275 0 0 0>  /* R13 */
            , <&key_physical_attrs 100 100 1200  275 0 0 0>  /* R14 */
            , <&key_physical_attrs 100 100 1400  275 0 0 0>  /* R15 */
            , <&key_physical_attrs 100 100 1500  275 0 0 0>  /* R16 */
            , <&key_physical_attrs 100 100 1600  275 0 0 0>  /* R17 */
            , <&key_physical_attrs 100 100 1300  300 0 0 0>  /* R18 */
            , <&key_physical_attrs 100 100  800  375 0 0 0>  /* R19 */
            , <&key_physical_attrs 100 100  900  375 0 0 0>  /* R20 */
            , <&key_physical_attrs 100 100 1000  375 0 0 0>  /* R21 */
            , <&key_physical_attrs 100 100 1100  375 0 0 0>  /* R22 */
            , <&key_physical_attrs 100 100 1200  375 0 0 0>  /* R23 */
            , <&key_physical_attrs 100 100 1400  375 0 0 0>  /* R24 */
            , <&key_physical_attrs 100 100 1500  375 0 0 0>  /* R25 */
            , <&key_physical_attrs 100 100 1600  375 0 0 0>  /* R26 */
            , <&key_physical_attrs 100 100 1300  400 0 0 0>  /* R27 */
            , <&key_physical_attrs 100 100    0  600 0 0 0>  /* phantom0 */
            , <&key_physical_attrs 100 100   20  600 0 0 0>  /* phantom1 */
            , <&key_physical_attrs 100 100   40  600 0 0 0>  /* phantom2 */
            , <&key_physical_attrs 100 100   60  600 0 0 0>  /* phantom3 */
            , <&key_physical_attrs 100 100   80  600 0 0 0>  /* phantom4 */
            , <&key_physical_attrs 100 100  100  600 0 0 0>  /* phantom5 */
            , <&key_physical_attrs 100 100  120  600 0 0 0>  /* phantom6 */
            , <&key_physical_attrs 100 100  140  600 0 0 0>  /* phantom7 */
            ;
    };
};
