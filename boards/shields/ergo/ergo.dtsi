/*
 * Shared definitions for both halves of the Ergo split.
 *
 * Combined matrix transform for the whole keyboard:
 *   - Left half  -> logical columns 0..4  (peripheral, col-offset 0)
 *   - Right half -> logical columns 5..10 (central,   col-offset 5)
 *
 * The left part of the map below is column-major (one visual row per
 * matrix column) exactly as the original left half was wired. The right
 * part is row-major. Each half keeps its own electrical layout; the
 * col-offset is what stitches them into one logical keymap.
 */

#include <dt-bindings/zmk/matrix_transform.h>

&pinctrl {
    i2c0_default: i2c0_default {
        group1 {
            psels = <NRF_PSEL(TWIM_SDA, 0, 4)>,
                    <NRF_PSEL(TWIM_SCL, 0, 5)>;
        };
    };

    i2c0_sleep: i2c0_sleep {
        group1 {
            psels = <NRF_PSEL(TWIM_SDA, 0, 4)>,
                    <NRF_PSEL(TWIM_SCL, 0, 5)>;
            low-power-enable;
        };
    };
};

&i2c0 {
    status = "okay";
    clock-frequency = <I2C_BITRATE_FAST>; /* CRITICAL: prevents severe input lag */
    pinctrl-0 = <&i2c0_default>;
    pinctrl-1 = <&i2c0_sleep>;
    pinctrl-names = "default", "sleep";
};

/ {
    chosen {
        zmk,matrix-transform = &default_transform;
    };

    default_transform: keymap_transform_0 {
        compatible = "zmk,matrix-transform";
        columns = <11>;
        rows = <6>;
        map = <
            /* ---- LEFT half: logical columns 0..4 (column-major) ---- */
            RC(0,0) RC(1,0) RC(2,0) RC(3,0) RC(4,0) RC(5,0)
            RC(0,1) RC(1,1) RC(2,1) RC(3,1) RC(4,1) RC(5,1)
            RC(0,2) RC(1,2) RC(2,2) RC(3,2) RC(4,2) RC(5,2)
            RC(0,3) RC(1,3) RC(2,3) RC(3,3) RC(4,3) RC(5,3)
            RC(3,4)

            /* ---- RIGHT half: logical columns 5..10 (row-major) ---- */
            RC(0,5) RC(0,6) RC(0,7) RC(0,8) RC(0,9) RC(0,10)
            RC(1,5) RC(1,6) RC(1,7) RC(1,8) RC(1,9) RC(1,10)
            RC(2,5) RC(2,6) RC(2,7) RC(2,8) RC(2,9) RC(2,10)
            RC(3,5) RC(3,6) RC(3,7) RC(3,8) RC(3,9) RC(3,10)
            RC(4,5) RC(4,6) RC(4,7) RC(4,8) RC(4,9) RC(4,10)
            RC(5,5) RC(5,6) RC(5,7) RC(5,8) RC(5,9) RC(5,10)
        >;
    };

    /*
     * Encoder lives physically on the LEFT (peripheral) at gpio0 2/3.
     * It is defined here in the shared .dtsi so the RIGHT (central) build
     * also has an *enabled* EC11 node - without one, ZMK forces the EC11
     * trigger thread off on the central and no encoder events are processed.
     * On the right these pins (D0/D1) are otherwise unused.
     */
    encoder0: encoder_0 {
        compatible = "alps,ec11";
        a-gpios = <&gpio0 2 (GPIO_ACTIVE_HIGH | GPIO_PULL_UP)>;
        b-gpios = <&gpio0 3 (GPIO_ACTIVE_HIGH | GPIO_PULL_UP)>;
        steps = <80>;
        status = "okay";
    };

    sensors {
        compatible = "zmk,keymap-sensors";
        sensors = <&encoder0>;
        triggers-per-rotation = <20>;
    };
};
